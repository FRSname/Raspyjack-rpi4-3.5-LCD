{
    "COLORS": {
        "BACKGROUND": "#000000",
        "BORDER": "#05ff00",
        "GAMEPAD": "#141494",
        "GAMEPAD_FILL": "#eeeeee",
        "SELECTED_TEXT": "#00ff55",
        "SELECTED_TEXT_BACKGROUND": "#2d0fff",
        "TEXT": "#05ff00"
    },
    "DISPLAY": {
        "WIDTH": 480,
        "HEIGHT": 320,
        "DRIVER": "LCD_480x320",
        "TYPE": "MPI3501",
        "INTERFACE": "framebuffer"
    },
    "LOCK": {
        "auto_lock_seconds": 0,
        "enabled": false,
        "pin_hash": ""
    },
    "PATHS": {
        "IMAGEBROWSER_START": "/root/Raspyjack/img/",
        "SCREENSAVER_GIF": "/root/Raspyjack/img/screensaver/default.gif"
    },
    "PINS": {
        "KEY1_PIN": 21,
        "KEY2_PIN": 20,
        "KEY3_PIN": 16,
        "KEY_DOWN_PIN": 19,
        "KEY_LEFT_PIN": 5,
        "KEY_PRESS_PIN": 13,
        "KEY_RIGHT_PIN": 26,
        "KEY_UP_PIN": 6
    },
    "TOUCH": {
        "DRIVER": "evdev",
        "DEVICE_NAMES": ["ADS7846 Touchscreen", "XPT2046"],
        "NOTE": "Touch calibration is handled by the kernel (ads7846 overlay). Use evdev-calibrator or xinput_calibrator if needed."
    }
}